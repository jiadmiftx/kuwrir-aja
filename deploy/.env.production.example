# Production secrets for the `backend` service in deploy/docker-compose.yml.
#
# Copy this file to `deploy/.env.production` on the VPS and fill in real values.
# `deploy/.env.production` is gitignored — never commit it.
#
# DB_HOST, REDIS_HOST and SERVER_MODE are already set directly in
# deploy/docker-compose.yml and do not need to be repeated here.

# JWT — MUST be a long random secret, do not use the code default
JWT_SECRET=change-this-to-a-very-long-random-secret-key
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# Cloudflare R2 (Object Storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_ACCESS_KEY_SECRET=your-r2-secret-key
R2_BUCKET_NAME=kuwrir-images
R2_PUBLIC_URL=https://images.yourdomain.com
